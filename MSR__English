let searchTimeout;
document.getElementById('search-input').addEventListener('input', e => {
  clearTimeout(searchTimeout);
  searchTimeout = setTimeout(() => filterProducts(e.target.value.trim().toLowerCase()), 150);
});

function filterProducts(q) {
  let anyVisible = false;
  document.querySelectorAll('.group-section').forEach(section => {
    const gi = parseInt(section.dataset.gi);
    const group = GROUPS[gi];
    const groupMatch = !q || group.name.toLowerCase().includes(q);
    let groupHasVisible = groupMatch;

    section.querySelectorAll('tbody tr:not(.subtotal-row)').forEach(tr => {
      const match = !q || groupMatch || tr.dataset.name.includes(q);
      tr.classList.toggle('hidden', !match);
      if (match) groupHasVisible = true;
    });

    section.style.display = groupHasVisible ? '' : 'none';
    if (groupHasVisible) anyVisible = true;
    // Auto-expand searched groups
    if (q && groupHasVisible && state.collapsed.has(gi)) toggleGroup(gi);
  });
  document.getElementById('no-results').classList.toggle('hidden', anyVisible);
}

