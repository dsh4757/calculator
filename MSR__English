<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Alkira 2026 MSRP Calculator</title>
<style>
  /* ── Reset & Base ─────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 14px; }
  body { font-family: 'Segoe UI', Arial, sans-serif; background: #f0f4f8; color: #222; min-height: 100vh; }

  /* ── Header ───────────────────────────────────────────────────── */
  #app-header {
    background: linear-gradient(135deg, #1F4E79 0%, #2E75B6 100%);
    color: #fff; padding: 0; position: sticky; top: 0; z-index: 100;
    box-shadow: 0 3px 12px rgba(0,0,0,0.25);
  }
  .header-top {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 20px 8px;
  }
  .header-title h1 { font-size: 1.3rem; font-weight: 700; letter-spacing: 0.02em; }
  .header-title p  { font-size: 0.75rem; opacity: 0.8; margin-top: 2px; }

  .summary-cards {
    display: flex; gap: 12px; align-items: center;
  }
  .summary-card {
    background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.25);
    border-radius: 8px; padding: 6px 16px; text-align: center; min-width: 150px;
  }
  .summary-card .label { font-size: 0.68rem; opacity: 0.85; text-transform: uppercase; letter-spacing: 0.08em; }
  .summary-card .value { font-size: 1.2rem; font-weight: 700; }
  .summary-card .value.green { color: #7fff7f; }

  /* ── Controls Bar ─────────────────────────────────────────────── */
  .controls-bar {
    background: #fff; border-bottom: 2px solid #e2e8f0;
    display: flex; flex-wrap: wrap; align-items: center; gap: 10px;
    padding: 10px 20px;
  }
  .control-group {
    display: flex; align-items: center; gap: 6px;
  }
  .control-group label { font-size: 0.8rem; font-weight: 600; color: #475569; white-space: nowrap; }
  .control-group input[type="number"] {
    width: 90px; padding: 5px 8px; border: 2px solid #2E75B6;
    border-radius: 6px; font-size: 0.9rem; font-weight: 700;
    color: #0000cc; background: #fff8dc; text-align: center;
    outline: none; transition: border-color 0.15s;
  }
  .control-group input[type="number"]:focus { border-color: #1F4E79; }
  .control-group .unit-label { font-size: 0.75rem; color: #64748b; }

  .search-wrapper {
    flex: 1; min-width: 200px; position: relative;
  }
  .search-wrapper input {
    width: 100%; padding: 6px 12px 6px 34px; border: 2px solid #cbd5e1;
    border-radius: 20px; font-size: 0.85rem; outline: none;
    transition: border-color 0.15s;
  }
  .search-wrapper input:focus { border-color: #2E75B6; }
  .search-wrapper .search-icon {
    position: absolute; left: 10px; top: 50%; transform: translateY(-50%);
    color: #94a3b8; font-size: 1rem; pointer-events: none;
  }

  .btn-group { display: flex; gap: 8px; margin-left: auto; }
  .btn {
    padding: 6px 14px; border: none; border-radius: 6px; font-size: 0.82rem;
    font-weight: 600; cursor: pointer; transition: all 0.15s; white-space: nowrap;
  }
  .btn-primary   { background: #1F4E79; color: #fff; }
  .btn-primary:hover { background: #163d63; }
  .btn-secondary { background: #e2e8f0; color: #334155; }
  .btn-secondary:hover { background: #cbd5e1; }
  .btn-success   { background: #16a34a; color: #fff; }
  .btn-success:hover { background: #15803d; }
  .btn-danger    { background: #dc2626; color: #fff; }
  .btn-danger:hover { background: #b91c1c; }
  .btn-sm { padding: 4px 10px; font-size: 0.75rem; }

  /* ── Main Content ─────────────────────────────────────────────── */
  #main { max-width: 1200px; margin: 0 auto; padding: 20px; }

  /* ── Group Section ────────────────────────────────────────────── */
  .group-section { margin-bottom: 10px; border-radius: 10px; overflow: hidden;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
  .group-header {
    display: flex; align-items: center; justify-content: space-between;
    background: #1F4E79; color: #fff; padding: 9px 16px;
    cursor: pointer; user-select: none; transition: background 0.15s;
  }
  .group-header:hover { background: #163d63; }
  .group-header .group-name { font-weight: 700; font-size: 0.88rem; letter-spacing: 0.02em; }
  .group-header .group-meta {
    display: flex; align-items: center; gap: 14px;
    font-size: 0.78rem; opacity: 0.9;
  }
  .group-header .group-total { font-weight: 700; font-size: 0.95rem; }
  .group-header .group-count { opacity: 0.75; }
  .chevron { transition: transform 0.2s; font-size: 0.8rem; }
  .group-header.collapsed .chevron { transform: rotate(-90deg); }

  /* ── Table ────────────────────────────────────────────────────── */
  .group-body { background: #fff; overflow: hidden; }
  .product-table { width: 100%; border-collapse: collapse; }
  .product-table thead tr {
    background: #dbeafe; font-size: 0.75rem; text-transform: uppercase;
    letter-spacing: 0.06em; color: #1e40af;
  }
  .product-table th { padding: 7px 12px; text-align: left; font-weight: 700; border-bottom: 2px solid #bfdbfe; }
  .product-table th.right { text-align: right; }
  .product-table th.center { text-align: center; }

  .product-table tbody tr { border-bottom: 1px solid #f1f5f9; transition: background 0.1s; }
  .product-table tbody tr:nth-child(even) { background: #f8fbff; }
  .product-table tbody tr:hover { background: #eff6ff; }
  .product-table tbody tr.active-row { background: #fef9c3 !important; }
  .product-table tbody tr.hidden { display: none; }

  .product-table td { padding: 6px 12px; vertical-align: middle; }
  .product-table td.name-col { font-size: 0.85rem; color: #1e293b; }
  .product-table td.unit-col { font-size: 0.75rem; color: #64748b; white-space: nowrap; }
  .product-table td.price-col { text-align: right; font-size: 0.85rem; color: #374151; font-feature-settings: "tnum"; }
  .product-table td.cost-col { text-align: right; font-weight: 600; font-size: 0.88rem;
    color: #1e3a5f; font-feature-settings: "tnum"; }
  .product-table td.annual-col { text-align: right; font-size: 0.85rem; color: #475569;
    font-feature-settings: "tnum"; }

  .qty-input {
    width: 72px; padding: 4px 6px; border: 2px solid #2E75B6; border-radius: 6px;
    font-size: 0.9rem; font-weight: 700; color: #0000cc; background: #fff8dc;
    text-align: center; outline: none; display: block; margin: 0 auto;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .qty-input:focus { border-color: #1F4E79; box-shadow: 0 0 0 3px rgba(30,78,121,0.12); }
  .qty-input.nonzero { background: #d1fae5; border-color: #16a34a; }

  /* ── Discount Input ───────────────────────────────────────────── */
  .disc-input {
    width: 60px; padding: 4px 4px; border: 2px solid #d97706; border-radius: 6px;
    font-size: 0.82rem; font-weight: 700; color: #92400e; background: #fffbeb;
    text-align: center; outline: none; display: block; margin: 0 auto;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .disc-input:focus { border-color: #b45309; box-shadow: 0 0 0 3px rgba(180,83,9,0.12); }
  .disc-input.custom { background: #fef3c7; border-color: #f59e0b; color: #78350f; }
  .net-col { text-align: right; font-weight: 700; font-size: 0.88rem;
    color: #166534; font-feature-settings: "tnum"; }

  /* ── Subtotal row ─────────────────────────────────────────────── */
  .subtotal-row td {
    background: #dbeafe !important; font-weight: 700; color: #1e40af;
    font-size: 0.85rem; padding: 6px 12px; border-top: 2px solid #93c5fd;
  }

  /* ── Grand Total Bar ──────────────────────────────────────────── */
  #grand-total-bar {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
    background: linear-gradient(135deg, #1F4E79, #2E75B6);
    color: #fff; display: flex; align-items: center; justify-content: space-between;
    padding: 10px 28px; box-shadow: 0 -3px 12px rgba(0,0,0,0.2);
  }
  #grand-total-bar .gt-left { font-size: 0.85rem; opacity: 0.85; }
  #grand-total-bar .gt-left strong { font-size: 1rem; display: block; }
  #grand-total-bar .gt-values { display: flex; gap: 28px; }
  #grand-total-bar .gt-val { text-align: center; }
  #grand-total-bar .gt-val .lbl { font-size: 0.7rem; opacity: 0.8; text-transform: uppercase; letter-spacing: 0.08em; }
  #grand-total-bar .gt-val .num { font-size: 1.4rem; font-weight: 700; }
  #grand-total-bar .gt-val .num.discounted { color: #86efac; }
  body { padding-bottom: 80px; }

  /* ── No-results ───────────────────────────────────────────────── */
  .no-results { text-align: center; color: #94a3b8; padding: 40px; font-size: 1rem; }

  /* ── Utility ──────────────────────────────────────────────────── */
  #main.hidden { display: none; }
  .no-results.hidden { display: none; }

  /* ── China visibility ─────────────────────────────────────────── */
  .china-hidden { display: none !important; }
  .btn-china-off { background: #fee2e2; color: #991b1b; border: 2px solid #fca5a5; }
  .btn-china-off:hover { background: #fecaca; }
  .btn-china-on  { background: #dcfce7; color: #166534; border: 2px solid #86efac; }
  .btn-china-on:hover  { background: #bbf7d0; }

  /* ── Badges ───────────────────────────────────────────────────── */
  .badge {
    display: inline-block; font-size: 0.65rem; font-weight: 700; padding: 1px 6px;
    border-radius: 10px; text-transform: uppercase; letter-spacing: 0.06em;
    vertical-align: middle; margin-left: 4px;
  }
  .badge-hour   { background: #dbeafe; color: #1e40af; }
  .badge-gb     { background: #d1fae5; color: #065f46; }
  .badge-month  { background: #fef3c7; color: #92400e; }
  .badge-flat   { background: #f1f5f9; color: #475569; }

  /* ── Quote Modal ──────────────────────────────────────────────── */
  .modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.55); z-index: 200;
    display: flex; align-items: center; justify-content: center; padding: 20px;
  }
  .modal-overlay.hidden { display: none; }
  .modal {
    background: #fff; border-radius: 12px; padding: 28px; max-width: 860px; width: 100%;
    max-height: 90vh; overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }
  .modal h2 { font-size: 1.2rem; color: #1F4E79; margin-bottom: 14px; }
  .modal-actions { display: flex; gap: 10px; margin-top: 20px; }

  /* ── Quote Form Fields ────────────────────────────────────────── */
  .q-form { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 16px; margin-bottom: 16px;
    padding: 14px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; }
  .q-form-full { grid-column: 1 / -1; }
  .q-label { display: block; font-size: 0.73rem; font-weight: 700; color: #475569;
    text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 3px; }
  .q-input { width: 100%; padding: 6px 10px; border: 1.5px solid #cbd5e1; border-radius: 6px;
    font-size: 0.85rem; color: #1e293b; outline: none; transition: border-color 0.15s; }
  .q-input:focus { border-color: #2E75B6; }
  .q-textarea { resize: vertical; min-height: 52px; }
  .q-logo-wrap { display: flex; align-items: center; gap: 12px; }
  .q-logo-preview { height: 44px; max-width: 160px; object-fit: contain; border-radius: 4px;
    border: 1px solid #e2e8f0; padding: 3px; background: #fff; display: none; }
  .q-logo-clear { font-size: 0.72rem; color: #dc2626; cursor: pointer; text-decoration: underline;
    white-space: nowrap; display: none; }

  /* ── Quote Preview ────────────────────────────────────────────── */
  #quote-preview { border: 1px solid #e2e8f0; border-radius: 8px; padding: 20px;
    background: #fff; margin-top: 4px; }
  .quote-meta { color: #64748b; font-size: 0.78rem; margin-bottom: 6px; }

  /* ── Print Styles ─────────────────────────────────────────────── */
  @media print {
    body { background: #fff; padding: 0; font-size: 11px; }
    #app-header, .controls-bar, #grand-total-bar, .btn-group,
    .modal-overlay, .group-header .chevron { display: none !important; }
    .group-section { box-shadow: none; margin-bottom: 6px; page-break-inside: avoid; }
    .group-header { background: #1F4E79 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .product-table tbody tr:nth-child(even) { background: #f8fbff !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .qty-input, .disc-input { border: 1px solid #ccc; background: #fff !important; color: #000; }
    #main { max-width: 100%; padding: 10px; }
    .print-only-header { display: block !important; }
  }
  .print-only-header { display: none; text-align: center; margin-bottom: 16px; }
  .print-only-header h2 { font-size: 1.1rem; color: #1F4E79; }
  .print-only-header p  { font-size: 0.75rem; color: #666; }

  /* ── Tooltip ──────────────────────────────────────────────────── */
  [title] { cursor: help; }

  /* ── Expand All / Collapse All toggle ─────────────────────────── */
  .view-toggle { font-size: 0.78rem; color: #2E75B6; cursor: pointer; text-decoration: underline; white-space: nowrap; }

  /* ── Wizard Overview ──────────────────────────────────────────── */
  #wizard-overview { max-width: 1200px; margin: 0 auto; padding: 30px 20px 40px; }
  #wizard-overview.hidden { display: none; }
  .wizard-header { text-align: center; margin-bottom: 28px; }
  .wizard-header h2 { font-size: 1.8rem; font-weight: 700; color: #1F4E79; margin-bottom: 6px; }
  .wizard-header p { color: #64748b; font-size: 0.9rem; }
  .wizard-steps { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-bottom: 28px; }
  .wizard-card {
    background: #fff; border: 2px solid #e2e8f0; border-radius: 12px;
    padding: 22px 16px 18px; cursor: pointer; transition: all 0.2s;
    display: flex; flex-direction: column; align-items: center; text-align: center;
    box-shadow: 0 2px 6px rgba(0,0,0,0.06);
  }
  .wizard-card:hover { border-color: #2E75B6; box-shadow: 0 6px 18px rgba(46,117,182,0.18); transform: translateY(-3px); }
  .wizard-card.has-items { border-color: #16a34a; background: #f0fdf4; }
  .wz-step-num { font-size: 0.65rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.1em; color: #94a3b8; margin-bottom: 8px; }
  .wizard-card.has-items .wz-step-num { color: #16a34a; }
  .wz-icon { font-size: 2rem; margin-bottom: 8px; line-height: 1; }
  .wz-label { font-size: 0.88rem; font-weight: 700; color: #1e293b; margin-bottom: 6px; line-height: 1.3; }
  .wz-desc { font-size: 0.71rem; color: #64748b; margin-bottom: 14px; line-height: 1.45; min-height: 42px; }
  .wz-stat { font-size: 0.75rem; font-weight: 600; color: #64748b;
    background: #f1f5f9; border-radius: 20px; padding: 3px 12px; margin-bottom: 14px; }
  .wizard-card.has-items .wz-stat { background: #dcfce7; color: #166534; }
  .wz-btn {
    background: #1F4E79; color: #fff; border: none; border-radius: 6px;
    padding: 8px 0; font-size: 0.78rem; font-weight: 600; cursor: pointer;
    transition: background 0.15s; width: 100%;
  }
  .wz-btn:hover { background: #163d63; }
  .wizard-card.has-items .wz-btn { background: #16a34a; }
  .wizard-card.has-items .wz-btn:hover { background: #15803d; }

  .wizard-footer { text-align: center; padding-top: 20px; border-top: 2px solid #e2e8f0; }
  .wizard-totals { display: flex; justify-content: center; gap: 48px; margin-bottom: 20px; }
  .wz-total-item { text-align: center; }
  .wz-total-item .wt-lbl { font-size: 0.7rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.07em; }
  .wz-total-item .wt-val { font-size: 1.4rem; font-weight: 700; color: #1F4E79; }
  .wz-total-item .wt-val.green { color: #16a34a; }

  /* ── Step Nav Bar ─────────────────────────────────────────────── */
  #step-nav { background: #1F4E79; color: #fff; padding: 10px 20px;
    display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  #step-nav.hidden { display: none; }
  #step-nav .sn-title { font-weight: 700; font-size: 0.95rem; text-align: center; flex: 1; }
  #step-nav .sn-sub { font-size: 0.72rem; opacity: 0.75; display: block; margin-top: 2px; }
  #step-nav .btn-nav { background: rgba(255,255,255,0.18); color:#fff; border:1px solid rgba(255,255,255,0.35);
    padding: 6px 14px; border-radius: 6px; font-size: 0.8rem; font-weight: 600;
    cursor: pointer; transition: background 0.15s; white-space: nowrap; }
  #step-nav .btn-nav:hover { background: rgba(255,255,255,0.32); }
  #step-nav .btn-nav.btn-nav-done { background: #16a34a; border-color: #16a34a; }
  #step-nav .btn-nav.btn-nav-done:hover { background: #15803d; }

  /* ── Step Legend ──────────────────────────────────────────────── */
  .main-content-row { display: flex; gap: 20px; align-items: flex-start; }
  #legend-panel {
    flex-shrink: 0; width: 180px;
    background: #fff; border-radius: 10px; padding: 14px 16px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.1); border: 1px solid #e2e8f0;
    position: sticky; top: 100px;
  }
  #legend-panel.hidden { display: none; }
  .legend-title {
    font-weight: 700; font-size: 0.8rem; color: #1F4E79;
    margin-bottom: 10px; padding-bottom: 8px;
    border-bottom: 2px solid #2E75B6; letter-spacing: 0.03em;
  }
  .legend-row {
    display: flex; align-items: center; gap: 8px;
    padding: 5px 0; font-size: 0.8rem; color: #374151;
    border-bottom: 1px solid #f1f5f9;
  }
  .legend-row:last-child { border-bottom: none; }
  .legend-key {
    font-weight: 700; background: #1F4E79; color: #fff;
    border-radius: 4px; padding: 2px 7px; font-size: 0.72rem;
    min-width: 34px; text-align: center; letter-spacing: 0.02em;
  }
  .legend-val { color: #475569; }
</style>
</head>
<body>

<!-- ══ HEADER ═══════════════════════════════════════════════════════ -->
<div id="app-header">
  <div class="header-top">
    <div class="header-title">
      <h1>Alkira 2026 MSRP Calculator</h1>
    </div>
    <div class="summary-cards">
      <div class="summary-card">
        <div class="label">MSRP Monthly</div>
        <div class="value" id="hdr-msrp-mo">$0</div>
      </div>
      <div class="summary-card">
        <div class="label">Net Monthly</div>
        <div class="value green" id="hdr-net-mo">$0</div>
      </div>
      <div class="summary-card">
        <div class="label">Net Annual</div>
        <div class="value green" id="hdr-net-yr">$0</div>
      </div>
    </div>
  </div>
</div>

<!-- ══ CONTROLS ══════════════════════════════════════════════════════ -->
<div class="controls-bar">
  <div class="control-group">
    <label for="inp-discount">Global Quote Discount %</label>
    <input type="number" id="inp-discount" value="0" min="0" max="100" step="0.5">
    <span class="unit-label">%</span>
    <button class="btn btn-secondary btn-sm" id="btn-apply-disc" title="Apply this discount to all line items">Apply to All</button>
  </div>
  <div class="search-wrapper">
    <span class="search-icon">🔍</span>
    <input type="text" id="search-input" placeholder="Search products or groups…" autocomplete="off">
  </div>
  <div class="btn-group">
    <button class="btn btn-china-off btn-sm" id="btn-china" title="Show or hide all China region products">🇨🇳 China: Hidden</button>
    <span class="view-toggle" id="toggle-all">Collapse All</span>
    <button class="btn btn-secondary btn-sm" id="btn-clear">Clear All</button>
    <button class="btn btn-success btn-sm" id="btn-csv">⬇ CSV</button>
    <button class="btn btn-primary btn-sm" id="btn-quote">📋 Quote</button>
    <button class="btn btn-secondary btn-sm" id="btn-print">🖨 Print</button>
  </div>
</div>

<!-- ══ WIZARD OVERVIEW ════════════════════════════════════════════════ -->
<div id="wizard-overview">
  <div class="wizard-header">
    <h2>Create a Quote</h2>
    <p>Configure each step, then click <strong>Build Quote</strong> when ready.</p>
  </div>
  <div class="wizard-steps" id="wizard-steps-grid">
    <!-- Rendered by renderWizard() -->
  </div>
  <div class="wizard-footer">
    <div class="wizard-totals">
      <div class="wz-total-item">
        <div class="wt-lbl">MSRP Monthly</div>
        <div class="wt-val" id="wz-msrp">–</div>
      </div>
      <div class="wz-total-item">
        <div class="wt-lbl">Net Monthly</div>
        <div class="wt-val green" id="wz-net">–</div>
      </div>
      <div class="wz-total-item">
        <div class="wt-lbl">Net Annual</div>
        <div class="wt-val green" id="wz-yr">–</div>
      </div>
    </div>
    <button class="btn btn-primary" id="btn-wizard-quote" style="padding:10px 32px;font-size:0.95rem;">📋 Build Quote</button>
  </div>
</div>

<!-- ══ STEP NAV BAR ════════════════════════════════════════════════ -->
<div id="step-nav" class="hidden">
  <button class="btn-nav btn-nav-done" id="btn-back-wizard">← Back to Wizard</button>
  <div style="text-align:center;flex:1">
    <span class="sn-title" id="sn-title"></span>
    <span class="sn-sub" id="sn-sub"></span>
