// ══ CSV EXPORT ════════════════════════════════════════════════════════════════
function buildCSVData(activeOnly = false) {
  const hrs  = getHours();
  const rows = [['Group','Product Name','Description','Billing Unit','Unit Price ($)','Quantity','Discount %','Monthly MSRP ($)','Monthly Net ($)','Annual Net ($)']];
  let subNetMo = 0;

  GROUPS.forEach((group, gi) => {
    if (group.autoCalc) return;
    group.products.forEach((prod, pi) => {
      const key  = `${gi}-${pi}`;
      if (!state.showChina && (group.china || prod.china)) return;
      const qty  = state.quantities[key] || 0;
      if (activeOnly && qty === 0) return;
      const disc  = group.noDisc ? 0 : getLineDisc(key);
      const mc    = monthCost(prod.p, prod.u, qty, prod.qtyScale);
      const netMc = mc * (1 - disc/100);
      const netYr = netMc * (prod.u === 'flat' ? 1 : 12);
      subNetMo += netMc;
      rows.push([
        group.name, prod.n, prod.d,
        prod.u === 'hour' ? `per hour (${hrs}hrs/mo)` : `per ${prod.u}`,
        prod.p.toFixed(2), qty, disc.toFixed(1) + '%',
        mc.toFixed(2), netMc.toFixed(2), netYr.toFixed(2)
      ]);
    });
  });

  // Auto-calc support row
  if (!activeOnly || subNetMo > 0) {
    const suppMo = subNetMo * 0.1;
    rows.push(['Support','Support','10% of total quote value','auto',
      suppMo.toFixed(2), 1, '0.0%',
      suppMo.toFixed(2), suppMo.toFixed(2), (suppMo * 12).toFixed(2)]);
  }
  return rows;
}

function downloadCSV(activeOnly) {
  const rows = buildCSVData(activeOnly);
  if (rows.length <= 1) { alert('No items to export.'); return; }
  const csv = rows.map(r => r.map(v => `"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n');
  const blob = new Blob([csv], {type:'text/csv'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `Alkira_MSRP_Quote_${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
}

document.getElementById('btn-csv').addEventListener('click', () => downloadCSV(false));

