// ══ WIZARD ═══════════════════════════════════════════════════════════════════

// Compute per-step monthly totals (both MSRP and Net)
function stepTotals(stepIdx) {
  let msrp = 0, net = 0, count = 0;
  const isAutoCalcStep = STEPS[stepIdx].groups.some(gi => GROUPS[gi].autoCalc);

  if (isAutoCalcStep) {
    // Compute 10% of all non-autoCalc selections
    let subNet = 0;
    GROUPS.forEach((group, gi) => {
      if (group.autoCalc) return;
      group.products.forEach((prod, pi) => {
        if (!state.showChina && (group.china || prod.china)) return;
        const key = `${gi}-${pi}`;
        const qty = state.quantities[key] || 0;
        if (!qty) return;
        const mc = monthCost(prod.p, prod.u, qty, prod.qtyScale);
        const disc = group.noDisc ? 0 : getLineDisc(key);
        subNet += mc * (1 - disc/100);
      });
    });
    const suppMo = subNet * 0.1;
    // Also include any non-autoCalc products in this step (e.g., Professional Services)
    STEPS[stepIdx].groups.forEach(gi => {
      const group = GROUPS[gi];
      if (group.autoCalc) { msrp += suppMo; net += suppMo; if (suppMo > 0) count++; return; }
      group.products.forEach((prod, pi) => {
        if (!state.showChina && (group.china || prod.china)) return;
        const key = `${gi}-${pi}`;
        const qty = state.quantities[key] || 0;
        if (!qty) return;
        const mc = monthCost(prod.p, prod.u, qty, prod.qtyScale);
        const disc = group.noDisc ? 0 : getLineDisc(key);
        msrp += mc; net += mc * (1 - disc/100); count++;
      });
    });
  } else {
    STEPS[stepIdx].groups.forEach(gi => {
      const group = GROUPS[gi];
      group.products.forEach((prod, pi) => {
        if (!state.showChina && (group.china || prod.china)) return;
        const key = `${gi}-${pi}`;
        const qty = state.quantities[key] || 0;
        if (!qty) return;
        const mc = monthCost(prod.p, prod.u, qty, prod.qtyScale);
        const disc = group.noDisc ? 0 : getLineDisc(key);
        msrp += mc; net += mc * (1 - disc/100); count++;
      });
    });
  }
  return { msrp, net, count };
}

function renderWizard() {
  const grid = document.getElementById('wizard-steps-grid');
  grid.innerHTML = '';
  let grandMsrp = 0, grandNet = 0;

  STEPS.forEach((step, si) => {
    const { msrp, net, count } = stepTotals(si);
    grandMsrp += msrp;
    grandNet  += net;
    const hasItems = count > 0;
    const fmtW = v => v === 0 ? '$0' : '$' + v.toLocaleString('en-US', {minimumFractionDigits:0, maximumFractionDigits:0});

    const card = document.createElement('div');
    card.className = 'wizard-card' + (hasItems ? ' has-items' : '');
    card.innerHTML = `
      <div class="wz-step-num">Step ${step.num}</div>
      <div class="wz-icon">${step.icon}</div>
      <div class="wz-label">${step.label}</div>
      <div class="wz-desc" ${si === 4 ? 'style="font-size:0.95rem;font-weight:600;color:#1F4E79;"' : ''}>${step.desc}</div>
      <div class="wz-stat">${hasItems ? `${count} item${count>1?'s':''} · ${fmtW(net)}/mo` : 'Not configured'}</div>
      <button class="wz-btn">${hasItems ? '✏️ Edit →' : 'Configure →'}</button>`;
    card.addEventListener('click', () => enterStep(si));
    grid.appendChild(card);
  });

  // Update wizard footer totals
  const fmtW = v => v === 0 ? '–' : '$' + v.toLocaleString('en-US', {minimumFractionDigits:0, maximumFractionDigits:0});
  document.getElementById('wz-msrp').textContent = fmtW(grandMsrp);
  document.getElementById('wz-net').textContent  = fmtW(grandNet);
  document.getElementById('wz-yr').textContent   = fmtW(grandNet * 12);
}

function enterStep(si) {
  state.activeStep = si;
  const step = STEPS[si];

  // Show/hide sections
  document.getElementById('wizard-overview').classList.add('hidden');
  document.getElementById('step-nav').classList.remove('hidden');
  document.getElementById('main').classList.remove('hidden');

  // Show legend on Step 1 (CXP) and Step 4 (Data Egress)
  const legend = document.getElementById('legend-panel');
  const l1 = document.getElementById('legend-step1');
  const l4 = document.getElementById('legend-step4');
  if (si === 0) {
    legend.classList.remove('hidden');
    l1.style.display = ''; l4.style.display = 'none';
  } else if (si === 3) {
    legend.classList.remove('hidden');
    l1.style.display = 'none'; l4.style.display = '';
  } else {
    legend.classList.add('hidden');
  }

  // Update step nav bar
  document.getElementById('sn-title').textContent = `Step ${step.num} — ${step.label}`;
  const snSub = document.getElementById('sn-sub');
  snSub.textContent = step.desc;
  snSub.style.fontSize  = si === 4 ? '0.95rem' : '';
  snSub.style.fontWeight = si === 4 ? '600' : '';
  snSub.style.opacity   = si === 4 ? '1' : '';

  // Next vs Done button
  const btnNext = document.getElementById('btn-next-step');
  if (si < STEPS.length - 1) {
    btnNext.textContent = `Next Step →`;
    btnNext.className = 'btn-nav btn-nav-done';
  } else {
    btnNext.textContent = '📋 Build Quote';
    btnNext.className = 'btn-nav btn-nav-done';
  }

  render();
}

function showWizardOverview() {
  state.activeStep = null;
  document.getElementById('wizard-overview').classList.remove('hidden');
  document.getElementById('step-nav').classList.add('hidden');
  document.getElementById('main').classList.add('hidden');
  document.getElementById('legend-panel').classList.add('hidden');
  renderWizard();
}

// Step nav buttons
document.getElementById('btn-back-wizard').addEventListener('click', showWizardOverview);
document.getElementById('btn-next-step').addEventListener('click', () => {
  if (state.activeStep < STEPS.length - 1) {
    enterStep(state.activeStep + 1);
  } else {
    showWizardOverview();
    document.getElementById('quote-modal').classList.remove('hidden');
    refreshQuotePreview();
  }
});

// Wizard quote button
document.getElementById('btn-wizard-quote').addEventListener('click', () => {
  document.getElementById('quote-modal').classList.remove('hidden');
  refreshQuotePreview();
});


// ══ PRINT ════════════════════════════════════════════════════════════════════
document.getElementById('btn-print').addEventListener('click', () => window.print());

// ══ INIT ════════════════════════════════════════════════════════════════════
showWizardOverview();
</script>
</body>
</html>
