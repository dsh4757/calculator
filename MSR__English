// ══ STATE ════════════════════════════════════════════════════════════════════
const state = { quantities: {}, discounts: {}, collapsed: new Set(), showChina: false, activeStep: null };

// ══ UTILS ════════════════════════════════════════════════════════════════════
function fmt(v, decimals=0) {
  if (v === 0) return '–';
  return '$' + v.toLocaleString('en-US', {minimumFractionDigits: decimals, maximumFractionDigits: decimals});
}
function fmtPrice(v) {
  return '$' + v.toFixed(2);
}
function unitBadge(u) {
  const map = {hour:['badge-hour','per hr'], gb:['badge-gb','per GB'], month:['badge-month','per mo'], flat:['badge-flat','flat']};
  const [cls, label] = map[u] || ['badge-flat','–'];
  return `<span class="badge ${cls}">${label}</span>`;
}
function getHours()    { return 730; }
function getDiscount() { return parseFloat(document.getElementById('inp-discount').value) || 0; }
function getLineDisc(key) {
  const v = state.discounts[key];
  return (v !== undefined && v !== null) ? v : getDiscount();
}
function monthCost(price, unit, qty, scale) {
  scale = scale || 1;
  if (unit === 'hour')  return price * qty * getHours();
  if (unit === 'gb')    return price * qty * scale;
  if (unit === 'month') return price * qty;
  if (unit === 'flat')  return price * qty;
  return 0;
}

// ══ RENDER ═══════════════════════════════════════════════════════════════════
function render() {
  const container = document.getElementById('groups-container');
  container.innerHTML = '';

  const stepFilter = state.activeStep !== null ? STEPS[state.activeStep].groups : null;

  GROUPS.forEach((group, gi) => {
    if (stepFilter && !stepFilter.includes(gi)) return;
    const section = document.createElement('div');
    section.className = 'group-section' + (group.china ? ' china-group' : '');
    section.dataset.gi = gi;

    // Group header
    const hdr = document.createElement('div');
    hdr.className = 'group-header' + (state.collapsed.has(gi) ? ' collapsed' : '');
    hdr.innerHTML = `
      <span class="group-name">${group.name}</span>
      <span class="group-meta">
        <span class="group-count">${group.products.length} products</span>
        <span class="group-total" id="gt-${gi}">–</span>
        <span class="chevron">▼</span>
      </span>`;
    hdr.addEventListener('click', () => toggleGroup(gi));
    section.appendChild(hdr);

    // Table
    const body = document.createElement('div');
    body.className = 'group-body';
    if (state.collapsed.has(gi)) body.style.display = 'none';

    const table = document.createElement('table');
    table.className = 'product-table';
    table.innerHTML = `<thead><tr>
      <th style="width:28%">Product Name</th>
      <th class="right" style="width:9%">Unit Price</th>
      <th class="center" style="width:7%">Billing</th>
      <th class="center" style="width:7%">Qty</th>
      <th class="center" style="width:7%" title="Per-line discount %. Change globally with Apply to All.">Disc %</th>
      <th class="right" style="width:13%">Monthly (MSRP)</th>
      <th class="right" style="width:13%">Monthly (Net)</th>
      <th class="right" style="width:16%">Annual (Net)</th>
    </tr></thead>`;
    const tbody = document.createElement('tbody');

    group.products.forEach((prod, pi) => {
      const key = `${gi}-${pi}`;
      const tr = document.createElement('tr');
      tr.dataset.key = key;
      tr.dataset.name = (prod.n + ' ' + prod.d + ' ' + group.name).toLowerCase();

      // ── Auto-calculated row (Support = 10% of total) ──
      if (group.autoCalc) {
        tr.innerHTML = `
          <td class="name-col" title="${prod.d}">${prod.n}</td>
          <td class="price-col" id="supp-price" style="color:#64748b;font-style:italic">–</td>
          <td class="unit-col" style="text-align:center"><span class="badge badge-flat">auto</span></td>
          <td style="text-align:center;color:#94a3b8;font-size:0.8rem">—</td>
          <td style="text-align:center;color:#94a3b8;font-size:0.8rem">—</td>
          <td class="cost-col" id="mc-${key}">–</td>
          <td class="net-col"  id="nm-${key}">–</td>
          <td class="annual-col" id="an-${key}">–</td>`;
        tbody.appendChild(tr);
        return;
      }

      // ── Normal row ──
      const qty  = state.quantities[key] || 0;
      const disc = group.noDisc ? 0 : getLineDisc(key);
      const mc   = monthCost(prod.p, prod.u, qty, prod.qtyScale);
      const netMc = mc * (1 - disc/100);
      const netYr = netMc * (prod.u === 'flat' ? 1 : 12);
      const isCustomDisc = !group.noDisc && state.discounts[key] !== undefined && state.discounts[key] !== getDiscount();

      if (prod.china) tr.classList.add('china-row');
      if (qty > 0) tr.classList.add('active-row');

      const discCell = group.noDisc
        ? `<td style="text-align:center;color:#94a3b8;font-size:0.8rem">—</td>`
        : `<td><input class="disc-input${isCustomDisc ? ' custom' : ''}" type="number"
             value="${disc}" min="0" max="100" step="0.5" data-key="${key}"
             title="Line-item discount %"></td>`;

      tr.innerHTML = `
        <td class="name-col" title="${prod.d}">${prod.n}</td>
        <td class="price-col">${fmtPrice(prod.p)}</td>
        <td class="unit-col" style="text-align:center">${unitBadge(prod.u)}</td>
        <td><input class="qty-input${qty > 0 ? ' nonzero' : ''}" type="number"
             value="${qty}" min="0" step="1" data-key="${key}"
             title="Enter quantity"></td>
        ${discCell}
        <td class="cost-col" id="mc-${key}">${fmt(mc)}</td>
        <td class="net-col" id="nm-${key}">${fmt(netMc)}</td>
        <td class="annual-col" id="an-${key}">${fmt(netYr)}</td>`;
      tbody.appendChild(tr);
    });

    // Subtotal row
    const stRow = document.createElement('tr');
    stRow.className = 'subtotal-row';
    stRow.innerHTML = `<td colspan="5" style="text-align:right">Group Subtotal</td>
      <td class="cost-col" id="st-mo-${gi}">–</td>
      <td class="net-col" id="st-nm-${gi}">–</td>
      <td class="annual-col" id="st-yr-${gi}">–</td>`;
    tbody.appendChild(stRow);

    table.appendChild(tbody);
    body.appendChild(table);
    section.appendChild(body);
    container.appendChild(section);
  });

  // Attach input listeners (event delegation)
  container.addEventListener('input', e => {
    if (e.target.classList.contains('qty-input')) {
      const key = e.target.dataset.key;
      const val = Math.max(0, parseInt(e.target.value) || 0);
      state.quantities[key] = val;
      e.target.value = val;
      e.target.classList.toggle('nonzero', val > 0);
      const tr = e.target.closest('tr');
      if (tr) tr.classList.toggle('active-row', val > 0);
      updateAll();
    } else if (e.target.classList.contains('disc-input')) {
      const key = e.target.dataset.key;
      const val = Math.min(100, Math.max(0, parseFloat(e.target.value) || 0));
      state.discounts[key] = val;
      e.target.value = val;
      e.target.classList.toggle('custom', val !== getDiscount());
      updateAll();
    }
  });

  updateAll();
  applyChinaVisibility();
  document.getElementById('print-date').textContent =
    'Printed: ' + new Date().toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'})
    + ' | Discount: ' + getDiscount() + '%';
}

// ══ CHINA VISIBILITY ══════════════════════════════════════════════════════════
function applyChinaVisibility() {
  const show = state.showChina;
  document.querySelectorAll('.china-group').forEach(el => el.classList.toggle('china-hidden', !show));
  document.querySelectorAll('.china-row').forEach(el => el.classList.toggle('china-hidden', !show));
  const btn = document.getElementById('btn-china');
  if (show) {
    btn.textContent = '🇨🇳 China: Shown';
    btn.className = 'btn btn-china-on btn-sm';
  } else {
    btn.textContent = '🇨🇳 China: Hidden';
    btn.className = 'btn btn-china-off btn-sm';
  }
}

document.getElementById('btn-china').addEventListener('click', () => {
  state.showChina = !state.showChina;
  applyChinaVisibility();
  updateAll();
});

function toggleGroup(gi) {
  if (state.collapsed.has(gi)) state.collapsed.delete(gi);
  else state.collapsed.add(gi);
  const section = document.querySelector(`.group-section[data-gi="${gi}"]`);
  const hdr  = section.querySelector('.group-header');
  const body = section.querySelector('.group-body');
  hdr.classList.toggle('collapsed', state.collapsed.has(gi));
  body.style.display = state.collapsed.has(gi) ? 'none' : '';
}

// ══ UPDATE CALCULATIONS ═══════════════════════════════════════════════════════
function updateAll() {
  let grandMsrpMo = 0, grandNetMo = 0;
  let totalItems = 0;

  // ── Pass 1: all non-autoCalc groups ──────────────────────────────
  GROUPS.forEach((group, gi) => {
    if (group.autoCalc) return;
    let groupMsrpMo = 0, groupNetMo = 0;
    group.products.forEach((prod, pi) => {
      const key  = `${gi}-${pi}`;
      if (!state.showChina && (group.china || prod.china)) return;
      const qty  = state.quantities[key] || 0;
      const disc = group.noDisc ? 0 : getLineDisc(key);
      const mc   = monthCost(prod.p, prod.u, qty, prod.qtyScale);
      const netMc = mc * (1 - disc/100);
      const netYr = netMc * (prod.u === 'flat' ? 1 : 12);
      if (qty > 0) totalItems++;

      const mcEl = document.getElementById(`mc-${key}`);
      const nmEl = document.getElementById(`nm-${key}`);
      const anEl = document.getElementById(`an-${key}`);
      if (mcEl) mcEl.textContent = fmt(mc);
      if (nmEl) nmEl.textContent = fmt(netMc);
      if (anEl) anEl.textContent = fmt(netYr);

      groupMsrpMo += mc;
      groupNetMo  += netMc;
    });

    const gtEl   = document.getElementById(`gt-${gi}`);
    const stMoEl = document.getElementById(`st-mo-${gi}`);
    const stNmEl = document.getElementById(`st-nm-${gi}`);
    const stYrEl = document.getElementById(`st-yr-${gi}`);
    if (gtEl)   gtEl.textContent   = groupNetMo > 0 ? fmt(groupNetMo) + '/mo' : '–';
    if (stMoEl) stMoEl.textContent = groupMsrpMo > 0 ? fmt(groupMsrpMo) : '–';
    if (stNmEl) stNmEl.textContent = groupNetMo  > 0 ? fmt(groupNetMo)  : '–';
    if (stYrEl) stYrEl.textContent = groupNetMo  > 0 ? fmt(groupNetMo * 12) : '–';

    grandMsrpMo += groupMsrpMo;
    grandNetMo  += groupNetMo;
  });

  // ── Pass 2: autoCalc groups (Support = 10% of subtotal so far) ──
  GROUPS.forEach((group, gi) => {
    if (!group.autoCalc) return;
    const suppMo  = grandNetMo * 0.1;
    const suppYr  = suppMo * 12;
    const fmtS = v => v > 0 ? '$' + v.toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2}) : '–';

    group.products.forEach((prod, pi) => {
      const key = `${gi}-${pi}`;
      const priceEl = document.getElementById('supp-price');
      if (priceEl) priceEl.textContent = fmtS(suppMo);
      const mcEl = document.getElementById(`mc-${key}`);
      const nmEl = document.getElementById(`nm-${key}`);
      const anEl = document.getElementById(`an-${key}`);
      if (mcEl) mcEl.textContent = fmt(suppMo);
      if (nmEl) nmEl.textContent = fmt(suppMo);
      if (anEl) anEl.textContent = fmt(suppYr);
    });

    const gtEl   = document.getElementById(`gt-${gi}`);
    const stMoEl = document.getElementById(`st-mo-${gi}`);
    const stNmEl = document.getElementById(`st-nm-${gi}`);
    const stYrEl = document.getElementById(`st-yr-${gi}`);
    if (gtEl)   gtEl.textContent   = suppMo > 0 ? fmt(suppMo) + '/mo' : '–';
    if (stMoEl) stMoEl.textContent = suppMo > 0 ? fmt(suppMo) : '–';
    if (stNmEl) stNmEl.textContent = suppMo > 0 ? fmt(suppMo) : '–';
    if (stYrEl) stYrEl.textContent = suppYr > 0 ? fmt(suppYr) : '–';

    grandMsrpMo += suppMo;
    grandNetMo  += suppMo;
  });

  const grandNetYr = grandNetMo * 12;

  // Update header
  document.getElementById('hdr-msrp-mo').textContent = fmt(grandMsrpMo);
  document.getElementById('hdr-net-mo').textContent  = fmt(grandNetMo);
  document.getElementById('hdr-net-yr').textContent  = fmt(grandNetYr);

  // Update grand total bar
  document.getElementById('gt-items').textContent    = totalItems + (totalItems === 1 ? ' item selected' : ' items selected');
  document.getElementById('gt-msrp-mo').textContent  = fmt(grandMsrpMo);
  document.getElementById('gt-msrp-yr').textContent  = fmt(grandMsrpMo * 12);
  document.getElementById('gt-net-mo').textContent   = fmt(grandNetMo);
  document.getElementById('gt-net-yr').textContent   = fmt(grandNetYr);
}

